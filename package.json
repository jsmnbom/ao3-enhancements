{
  "name": "ao3-enhancements",
  "type": "module",
  "version": "0.7.0",
  "private": true,
  "description": "Various tweaks and enhancements for ArchiveOfOurOwn.org",
  "author": "jsmnbom",
  "license": "MIT",
  "imports": {
    "#uno.config": "./uno.config.ts",
    "#dom": "./src/common/dom.ts",
    "#common": "./src/common/index.ts",
    "#img/*": "./src/img/*",
    "#icons/*": "./src/icons/*",
    "#content_script/*": "./src/content_script/*"
  },
  "scripts": {
    "clean": "rm -rf build",
    "build": "pnpm run build:prod:firefox && pnpm run build:prod:chrome",
    "dist": "node scripts/dist.ts",
    "dist:lint": "pnpm run dist:firefox:lint",
    "build:dev:firefox": "BROWSER=firefox NODE_ENV=development node scripts/builder/build.ts build",
    "build:prod:firefox": "BROWSER=firefox NODE_ENV=production node scripts/builder/build.ts build",
    "serve:dev:firefox": "BROWSER=firefox NODE_ENV=development node scripts/builder/build.ts serve",
    "serve:prod:firefox": "BROWSER=firefox NODE_ENV=production node scripts/builder/build.ts serve",
    "start:firefox": "web-ext --config=scripts/web-ext.firefox.mjs run",
    "start:firefox-android": "web-ext --config=scripts/web-ext.firefox-android.mjs run --target firefox-android",
    "dist:firefox:lint": "web-ext --config=scripts/web-ext.firefox.mjs lint",
    "build:dev:chrome": "BROWSER=chrome NODE_ENV=development node scripts/builder/build.ts build",
    "build:prod:chrome": "BROWSER=chrome NODE_ENV=production node scripts/builder/build.ts build",
    "serve:dev:chrome": "BROWSER=chrome NODE_ENV=development node scripts/builder/build.ts serve",
    "serve:prod:chrome": "BROWSER=chrome NODE_ENV=production node scripts/builder/build.ts serve",
    "start:chrome": "web-ext --config=scripts/web-ext.chrome.mjs run --target chromium"
  },
  "dependencies": {
    "@antfu/utils": "^9.3.0",
    "@vue/reactivity": "^3.5.38",
    "@vue/runtime-core": "^3.5.38",
    "@vue/runtime-dom": "^3.5.38",
    "@vueuse/core": "^14.3.0",
    "change-case": "^5.4.4",
    "reka-ui": "^2.10.0",
    "typed-query-selector": "^2.12.2",
    "vue": "^3.5.38"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@iconify-json/codicon": "^1.2.61",
    "@iconify-json/line-md": "^1.2.16",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/tabler": "^1.2.35",
    "@iconify/utils": "^3.1.3",
    "@types/firefox-webext-browser": "^143.0.0",
    "@types/node": "^26.0.0",
    "@types/semver": "^7.7.1",
    "@unocss/eslint-plugin": "^66.7.2",
    "@unocss/rule-utils": "^66.7.2",
    "@unocss/vite": "^66.7.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "dot-prop": "^10.1.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-format": "^2.0.1",
    "lightningcss": "^1.32.0",
    "parse5": "^8.0.1",
    "preact": "^10.29.2",
    "rollup-plugin-visualizer": "^6.0.11",
    "semver": "^7.8.5",
    "svgo": "^4.0.1",
    "type-fest": "^5.7.0",
    "typescript": "^6.0.3",
    "unimport": "^6.3.0",
    "unocss": "^66.7.2",
    "unocss-preset-animations": "^1.3.0",
    "unplugin": "^3.0.0",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-icons": "^23.0.1",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.0.16",
    "vite-plugin-vue-devtools": "^8.1.3",
    "web-ext": "^10.4.0",
    "zx": "^8.8.5"
  },
  "trustedDependencies": [
    "esbuild"
  ],
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "node-fetch"
      ]
    }
  }
}
